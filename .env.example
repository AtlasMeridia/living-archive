# --- Inference ---
# Both pipelines dispatch through the Anthropic SDK using a Max Plan OAuth
# token. Legacy CLI / Codex / Ollama / direct-API paths were removed on
# 2026-04-21 during the pare-down.

# OAuth model for SDK calls (default: claude-sonnet-4-20250514)
# OAUTH_MODEL=claude-sonnet-4-20250514

# OAuth token (auto-detected from ~/.hermes/.env if not set)
# CLAUDE_CODE_OAUTH_TOKEN=...

# Standard API key — only needed by contact_triage.py (direct Haiku calls).
# Everything else uses the OAuth token above.
# ANTHROPIC_API_KEY=sk-ant-...

# Immich instance — only needed for photo pipeline
IMMICH_URL=http://mneme.local:2283
IMMICH_API_KEY=your-immich-api-key

# NAS media root (mounted via AFP)
MEDIA_ROOT=/Volumes/MNEME/05_PROJECTS/Living Archive/Family/Media

# Photo slice target (relative to MEDIA_ROOT)
SLICE_PATH=2009 Scanned Media/1978

# NAS documents root (mounted via AFP)
DOCUMENTS_ROOT=/Volumes/MNEME/05_PROJECTS/Living Archive/Family/Documents

# Document slice target (relative to DOCUMENTS_ROOT)
DOC_SLICE_PATH=Liu Family Trust Filings & Documents

# Batch / pacing controls (optional — defaults: unlimited, no delay)
# DOC_BATCH_SIZE=20        # Max documents per invocation (0 = all)
# DOC_PACING_DELAY=2       # Seconds between documents
